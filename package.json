{
  "name": "x402-webcash",
  "version": "0.5.2",
  "description": "x402 payment scheme for webcash bearer e-cash — facilitator, middleware, and a transport-agnostic client that auto-settles HTTP 402 challenges from a local wallet.",
  "license": "MIT",
  "author": "Nate Feldmann",
  "homepage": "https://github.com/feldmannn/x402-webcash",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feldmannn/x402-webcash.git"
  },
  "bugs": {
    "url": "https://github.com/feldmannn/x402-webcash/issues"
  },
  "keywords": [
    "x402",
    "webcash",
    "http-402",
    "bearer-token",
    "e-cash",
    "agent-payments",
    "micropayments"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    }
  },
  "files": [
    "dist",
    "specs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "facilitator": "tsx src/server.ts",
    "example": "tsx examples/express-server.ts",
    "example:client": "tsx examples/fetch-client.ts",
    "test": "node --test --import tsx tests/basic.test.ts tests/middleware.test.ts tests/client.test.ts tests/split.test.ts tests/security.test.ts tests/integration.test.ts tests/e2e.test.ts tests/mcp-settler.test.ts"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
